# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_CRYPTO_KEY: 32-byte secret key (64 hex characters or 32 characters) for AES-256-GCM encryption
DATABASE_CRYPTO_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# UPSTASH_REDIS_REST_URL: The REST URL for Upstash Redis database
UPSTASH_REDIS_REST_URL="YOUR_UPSTASH_REDIS_REST_URL"

# UPSTASH_REDIS_REST_TOKEN: The REST token for Upstash Redis database
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"

# ADMIN_SEED_PASSWORD: Password untuk admin seed script `npx tsx scripts/seed-admin.ts` (min. 8 karakter)
ADMIN_SEED_PASSWORD="GANTI_DENGAN_PASSWORD_KUAT"

# DATABASE_URL: The connection string for the Neon Serverless Postgres database
DATABASE_URL="postgres://user:password@hostname/dbname?sslmode=require"

# =============================================================================
# MIDTRANS PAYMENT GATEWAY
# =============================================================================

# MIDTRANS_SERVER_KEY: Server Key dari Midtrans Dashboard (Settings > Access Keys)
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxxxxxxxxx"

# MIDTRANS_CLIENT_KEY: Client Key dari Midtrans Dashboard
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxxxxxx"

# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY: Client Key (exposed ke browser untuk Snap.js)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxxxxxx"

# MIDTRANS_IS_PRODUCTION: Set "true" untuk production, "false" untuk sandbox
MIDTRANS_IS_PRODUCTION="false"

# NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION: Flag production untuk client-side Snap URL
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"

# =============================================================================
# NEXT-AUTH (CMS Admin Authentication)
# =============================================================================

# NEXTAUTH_SECRET: Secret key untuk enkripsi JWT session
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="GANTI_DENGAN_64_KARAKTER_HEX_RANDOM"

# NEXTAUTH_URL: URL base aplikasi (wajib untuk NextAuth)
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# ANALYTICS (Google Analytics / Umami)
# =============================================================================

# Google Analytics 4 — set Measurement ID untuk mengaktifkan GA4
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Umami Analytics — set Website ID untuk mengaktifkan Umami
# NEXT_PUBLIC_UMAMI_WEBSITE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# NEXT_PUBLIC_UMAMI_URL="https://cloud.umami.is"
